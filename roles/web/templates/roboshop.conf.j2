proxy_http_version 1.1;

# AWS VPC DNS resolver (works in EC2)
resolver 169.254.169.253 valid=10s ipv6=off;

location /images/ {
  expires 5s;
  root   /usr/share/nginx/html;
  try_files $uri /images/placeholder.jpg;
}

# ALB health check (simple 200)
location = /health {
  default_type text/plain;
  return 200 "OK\n";
}

# Forward all API to internal ALB (safe for AMI bake even if ALB doesn't exist yet)
location /api/ {
  set $upstream "http://{{ internal_alb_host }}:{{ internal_alb_port }}";
  proxy_pass $upstream;

  # preserve original host for internal ALB host-based routing
  proxy_set_header Host $host;

  proxy_set_header X-Forwarded-Proto $scheme;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
}