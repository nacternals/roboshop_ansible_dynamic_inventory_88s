proxy_http_version 1.1;

resolver 169.254.169.253 valid=10s ipv6=off;

set $internal_alb "internal-roboshop-dev-alb-int-596289607.us-east-1.elb.amazonaws.com";

location /images/ {
  expires 5s;
  root /usr/share/nginx/html;
  try_files $uri /images/placeholder.jpg;
}

location = /health {
  default_type text/plain;
  return 200 "OK\n";
}

# -----------------------------
# Catalogue Service
# -----------------------------
location /api/catalogue/ {
  rewrite ^/api/catalogue/(.*)$ /$1 break;

  proxy_set_header Host catalogue.dev.optimusprime.uno;
  proxy_set_header X-Forwarded-Proto $scheme;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

  proxy_pass http://$internal_alb;
}

# -----------------------------
# User Service
